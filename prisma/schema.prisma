generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Consultation {
  id                    Int                     @id @default(autoincrement())
  title                 String
  slug                  String                  @unique
  summary               String                  @db.Text
  imageUrl              String?
  duration              Int?
  bookable              Boolean                 @default(true)
  unavailableText       String?                 @db.Text
  customerFields        String?                 @default("name,email")
  price                 Int
  focus                 String
  badge                 String
  featured              Boolean                 @default(false)
  sortOrder             Int                     @default(0)
  bookingDaysAhead      Int                     @default(14)
  allowSameDayBooking   Boolean                 @default(true)
  slotDurationMinutes   Int                     @default(60)
  bookingBufferMinutes  Int                     @default(0)
  disabledWeekdays      String?
  allowedMonths         String?
  disabledMonthDays     String?
  disabledDaysByMonth   String?                 @db.Text
  disableFrenchHolidays Boolean                 @default(false)
  createdAt             DateTime                @default(now())
  bookings              Booking[]
  promotions            PromotionConsultation[]
}

model Booking {
  id                 Int          @id @default(autoincrement())
  name               String?
  firstName          String?
  email              String?
  phone              String?
  message            String?
  preferredDate      DateTime?
  paymentStatus      String       @default("pending")
  orderStatus        String       @default("new")
  stripeSessionId    String?      @unique
  consultation       Consultation @relation(fields: [consultationId], references: [id])
  consultationId     Int
  originalPriceCents Int
  paidAmountCents    Int
  promotionCode      String?      @db.VarChar(64)
  discountPercent    Int?
  promotion          Promotion?   @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  promotionId        Int?
  createdAt          DateTime     @default(now())

  @@index([promotionId])
}

model Promotion {
  id          Int                     @id @default(autoincrement())
  code        String                  @unique @db.VarChar(64)
  title       String                  @db.VarChar(120)
  bannerText  String                  @db.VarChar(191)
  percentOff  Int
  active      Boolean                 @default(true)
  allProducts Boolean                 @default(false)
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  products    PromotionConsultation[]
  bookings    Booking[]

  @@index([active, startsAt, endsAt])
}

model PromotionConsultation {
  promotion      Promotion    @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  promotionId    Int
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  consultationId Int

  @@id([promotionId, consultationId])
  @@index([consultationId])
}

model GoogleCalendarConnection {
  id                    Int      @id
  googleAccountId       String   @db.VarChar(255)
  googleEmail           String   @db.VarChar(320)
  encryptedRefreshToken String   @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
