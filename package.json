{
  "name": "rocktheards",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "next start -p 3030",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:format": "prisma format",
    "db:dev:generate": "PRISMA_ENV_FILE=.env prisma generate",
    "db:dev:migrate:baseline": "PRISMA_ENV_FILE=.env prisma migrate resolve --applied 20260713000000_baseline",
    "db:dev:migrate": "PRISMA_ENV_FILE=.env prisma migrate dev",
    "db:dev:migrate:create": "PRISMA_ENV_FILE=.env prisma migrate dev --create-only",
    "db:dev:migrate:status": "PRISMA_ENV_FILE=.env prisma migrate status",
    "db:dev:push": "PRISMA_ENV_FILE=.env prisma db push",
    "db:dev:seed": "PRISMA_ENV_FILE=.env prisma db seed",
    "db:dev:studio": "PRISMA_ENV_FILE=.env prisma studio",
    "db:dev:validate": "PRISMA_ENV_FILE=.env prisma validate",
    "db:prod:generate": "PRISMA_ENV_FILE=.env.production prisma generate",
    "db:prod:migrate:baseline": "PRISMA_ENV_FILE=.env.production prisma migrate resolve --applied 20260713000000_baseline",
    "db:prod:migrate": "PRISMA_ENV_FILE=.env.production prisma migrate deploy",
    "db:prod:migrate:status": "PRISMA_ENV_FILE=.env.production prisma migrate status",
    "db:prod:validate": "PRISMA_ENV_FILE=.env.production prisma validate"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "7.8.0",
    "@prisma/client": "7.8.0",
    "dotenv": "^17.2.3",
    "google-auth-library": "10.5.0",
    "googleapis": "^173.0.0",
    "libphonenumber-js": "^1.13.8",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prisma": "7.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@prisma/client",
    "@prisma/engines",
    "prisma",
    "sharp",
    "unrs-resolver"
  ]
}
